  "plausibleAlternativeCatalog": [
    {
      "alternativeId": "ALT-GFX-FLIP-COPY",
      "defectClass": "flip-copy-confusion",
      "statefulness": "stateless",
      "applicableCategoryIds": [
        "framebuffer-lifecycle",
        "texture-sampling"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "WITNESSED-FAILURE-MODES.md #1 — the archetype: a flip pass that was algebraically a copy survived commit, push, and completion report"
      }
    },
    {
      "alternativeId": "ALT-GFX-PASS-REORDER",
      "defectClass": "render-pass-reordering",
      "statefulness": "stateful",
      "applicableCategoryIds": [
        "render-pass-order",
        "framebuffer-lifecycle"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "PHOSPHENE-GOAL.md Exactness Standard (execution and pass order) + witnessed projectM RenderFrame ordering defects in the failed port (motion vectors before warp, swap after composite)"
      }
    },
    {
      "alternativeId": "ALT-GFX-PASS-OMISSION",
      "defectClass": "render-pass-omission",
      "statefulness": "stateless",
      "applicableCategoryIds": [
        "render-pass-order"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "WITNESSED-FAILURE-MODES.md #2 — the legacy correction flip pass omitted under an equivalence argument whose premise was the broken flip math"
      }
    },
    {
      "alternativeId": "ALT-GFX-BLEND-SUBSTITUTION",
      "defectClass": "blend-state-substitution",
      "statefulness": "stateless",
      "applicableCategoryIds": [
        "render-state"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "PHOSPHENE-GOAL.md Exactness Standard (blend, depth, raster, and other render state) + witnessed VideoEcho blend-transition defects in the failed port"
      }
    },
    {
      "alternativeId": "ALT-GFX-STALE-FRAMEBUFFER",
      "defectClass": "stale-framebuffer-content-reuse",
      "statefulness": "stateful",
      "applicableCategoryIds": [
        "framebuffer-lifecycle"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "WITNESSED-FAILURE-MODES.md #4 — structure claimed as implementation around framebuffer swap/reset lifecycles; feedback pipelines make stale-target reuse a first-class defect"
      }
    },
    {
      "alternativeId": "ALT-GFX-SAMPLER-WRONG-DEFAULT",
      "defectClass": "sampler-or-wrap-mode-wrong-default",
      "statefulness": "stateless",
      "applicableCategoryIds": [
        "texture-sampling"
      ],
      "grounding": {
        "type": "authority-or-witnessed-failure",
        "reference": "PHOSPHENE-GOAL.md Exactness Standard (textures, sampling) — sampler defaults differ across source engines and silently change sampling behavior"
      }
    }
