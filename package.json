{
  "name": "sip-phosphene",
  "version": "0.1.0",
  "description": "PHOSPHENE Studio — WebGPU scene authoring environment for audio-reactive visualization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "build:portable": "vite build -c vite.onefile.config.ts",
    "scenes": "vite-node scripts/gen-scenes.mjs",
    "validate:scenes": "vite-node scripts/validate-scenes.mjs"
  },
  "dependencies": {
    "@codemirror/language": "^6.10.0",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "codemirror": "^6.0.1",
    "fast-xml-parser": "^5.10.0",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@webgpu/types": "^0.1.44",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^2.1.0",
    "wgsl_reflect": "^1.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Stuff-is-Parts/sip-phosphene.git"
  }
}
