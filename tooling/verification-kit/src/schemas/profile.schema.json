{
  "$id": "profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId", "name", "version", "hash", "technicalDomainOrProductForm",
    "categoriesSupplied", "providersSuppliedOrRequired", "adapterCapabilitiesSuppliedOrRequired",
    "positiveControls", "negativeControlDefectClasses", "ciJobs",
    "applicabilityPredicates", "limitations", "evidenceClassRules",
    "discriminatingFixtureRequirements", "equivalenceClaimRules", "runtimeEffectControls",
    "plausibleAlternativeCatalog", "alternativeEvaluators", "divergenceClassificationRules",
    "oraclePrecedenceRules", "inventoryCoverageRules", "customMechanismSelfTestRules"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "profileId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "description": "sha256:<hex> over the profile content with this field set to the fixed placeholder 'sha256:SELF'." },
    "technicalDomainOrProductForm": { "type": "string" },
    "categoriesSupplied": { "type": "array", "items": { "type": "string" } },
    "providersSuppliedOrRequired": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["providerId", "mode"],
        "properties": {
          "providerId": { "type": "string" },
          "mode": { "type": "string", "enum": ["required", "supplied", "optional"] },
          "versionConstraint": { "type": "string" }
        }
      }
    },
    "adapterCapabilitiesSuppliedOrRequired": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilityId", "mode"],
        "properties": {
          "capabilityId": { "type": "string" },
          "mode": { "type": "string", "enum": ["required", "supplied", "optional"] }
        }
      }
    },
    "positiveControls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["controlId", "categoryId", "expectedResult"],
        "properties": {
          "controlId": { "type": "string" },
          "categoryId": { "type": "string" },
          "expectedResult": { "type": "string", "enum": ["PASS"] }
        }
      }
    },
    "negativeControlDefectClasses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["defectClassId", "categoryId", "expectedFailureCode", "expectedFirstDivergence"],
        "properties": {
          "defectClassId": { "type": "string" },
          "categoryId": { "type": "string" },
          "expectedFailureCode": { "type": "string" },
          "expectedFirstDivergence": { "type": "string" }
        }
      }
    },
    "ciJobs": { "type": "array", "items": { "type": "string" } },
    "applicabilityPredicates": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "evidenceClassRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "rawAuthorityMustRemainByteExact", "derivedEvidenceMustReferenceSource", "perConstituentAuthorityIdentityRequired"],
        "properties": {
          "ruleId": { "type": "string" },
          "rawAuthorityMustRemainByteExact": { "type": "boolean", "const": true },
          "derivedEvidenceMustReferenceSource": { "type": "boolean", "const": true },
          "perConstituentAuthorityIdentityRequired": { "type": "boolean", "const": true }
        }
      }
    },
    "discriminatingFixtureRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["categoryId", "requiredAlternativeClasses", "requiredDiscriminationCheckId", "requiredAlternativeEvaluatorIds", "effectiveSetRule"],
        "properties": {
          "categoryId": { "type": "string" },
          "requiredAlternativeClasses": { "type": "array", "items": { "type": "string" } },
          "requiredDiscriminationCheckId": { "type": "string" },
          "requiredAlternativeEvaluatorIds": { "type": "array", "items": { "type": "string" } },
          "effectiveSetRule": { "type": "string", "const": "union-with-claim-and-project-binding" }
        }
      }
    },
    "equivalenceClaimRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["categoryId", "proofRequired", "completeApplicableDomainRequired"],
        "properties": {
          "categoryId": { "type": "string" },
          "proofRequired": { "type": "boolean", "const": true },
          "completeApplicableDomainRequired": { "type": "boolean", "const": true }
        }
      }
    },
    "runtimeEffectControls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["categoryId", "controlId", "actualProductPathRequired", "controlledInterventionOrTraceRequired"],
        "properties": {
          "categoryId": { "type": "string" },
          "controlId": { "type": "string" },
          "actualProductPathRequired": { "type": "boolean", "const": true },
          "controlledInterventionOrTraceRequired": { "type": "boolean", "const": true }
        }
      }
    },
    "plausibleAlternativeCatalog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alternativeId", "defectClass", "statefulness", "applicableCategoryIds", "grounding"],
        "properties": {
          "alternativeId": { "type": "string" },
          "defectClass": { "type": "string" },
          "statefulness": { "type": "string", "enum": ["stateless", "stateful"] },
          "applicableCategoryIds": { "type": "array", "items": { "type": "string" } },
          "grounding": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "reference"],
            "properties": {
              "type": { "type": "string" },
              "reference": { "type": "string" }
            }
          }
        }
      }
    },
    "alternativeEvaluators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evaluatorId", "alternativeId", "providerOrImplementation", "expectedDivergence", "negativeControlId"],
        "properties": {
          "evaluatorId": { "type": "string" },
          "alternativeId": { "type": "string" },
          "providerOrImplementation": { "type": "string" },
          "expectedDivergence": { "type": "string" },
          "negativeControlId": { "type": "string" }
        }
      }
    },
    "divergenceClassificationRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["categoryId", "representationLevelRequiresUnchangedAlgorithmStateOrderAndPath", "representationLevelRequiresEvidenceOfCauseAndMagnitude", "behavioralOrPathChangeRequiresEquivalenceClaim"],
        "properties": {
          "categoryId": { "type": "string" },
          "representationLevelRequiresUnchangedAlgorithmStateOrderAndPath": { "type": "boolean", "const": true },
          "representationLevelRequiresEvidenceOfCauseAndMagnitude": { "type": "boolean", "const": true },
          "behavioralOrPathChangeRequiresEquivalenceClaim": { "type": "boolean", "const": true }
        }
      }
    },
    "oraclePrecedenceRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["policyId", "categoryId", "orderedOracleClassesStrongestFirst", "strongestAvailableRequired", "bypassRequiresIndependentUnavailabilityEvidence"],
        "properties": {
          "policyId": { "type": "string" },
          "categoryId": { "type": "string" },
          "orderedOracleClassesStrongestFirst": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["reference-execution", "mechanical-extraction", "formal-derivation", "controlled-observation"] }
          },
          "requiredProviderOrCapabilityByClass": {
            "type": "object",
            "additionalProperties": { "type": "array", "items": { "type": "string" } }
          },
          "strongestAvailableRequired": { "type": "boolean", "const": true },
          "bypassRequiresIndependentUnavailabilityEvidence": { "type": "boolean", "const": true },
          "optionalOracleClasses": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["defaultPermission"],
              "properties": {
                "defaultPermission": { "type": "string", "const": "forbidden-unless-explicitly-authorized" },
                "requiresApplicabilityRule": { "type": "boolean" },
                "requiresAuthoritativePremisesAndReproducibleProcedure": { "type": "boolean" },
                "requiresStrongerOracleUnavailabilityEvidence": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "inventoryCoverageRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["categoryId", "inventoryProcedureId", "stableInventoryIdsRequired", "everyItemRequiresClaimFixtureAndExecutableCheck", "claimAggregationMayNotReducePerItemCoverage"],
        "properties": {
          "categoryId": { "type": "string" },
          "inventoryProcedureId": { "type": "string" },
          "stableInventoryIdsRequired": { "type": "boolean", "const": true },
          "everyItemRequiresClaimFixtureAndExecutableCheck": { "type": "boolean", "const": true },
          "claimAggregationMayNotReducePerItemCoverage": { "type": "boolean", "const": true }
        }
      }
    },
    "customMechanismSelfTestRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicCommandOrProcessBoundaryRequired", "internalDecisionLogicMayNotBeImportedOrDuplicated", "observableFailureSignatureRequired", "structurallyValidSemanticallyInadequateControlRequired", "proxyRequiresIndependentEquivalenceProof"],
      "properties": {
        "publicCommandOrProcessBoundaryRequired": { "type": "boolean", "const": true },
        "internalDecisionLogicMayNotBeImportedOrDuplicated": { "type": "boolean", "const": true },
        "observableFailureSignatureRequired": { "type": "boolean", "const": true },
        "structurallyValidSemanticallyInadequateControlRequired": { "type": "boolean", "const": true },
        "proxyRequiresIndependentEquivalenceProof": { "type": "boolean", "const": true }
      }
    }
  }
}
