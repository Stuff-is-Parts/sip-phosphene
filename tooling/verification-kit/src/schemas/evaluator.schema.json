{
  "$id": "evaluator.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evaluatorId", "alternativeId", "defectClass", "statefulness",
    "applicableClasses", "entryPoint", "expectedDivergence", "grounding",
    "negativeControlSignature"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "evaluatorId": { "type": "string", "minLength": 1 },
    "alternativeId": { "type": "string", "minLength": 1 },
    "defectClass": { "type": "string", "minLength": 1 },
    "statefulness": { "type": "string", "enum": ["stateless", "stateful"] },
    "applicableClasses": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "entryPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "export"],
      "properties": {
        "module": { "type": "string", "description": "Repo-relative path to the ESM module implementing the defective alternative." },
        "export": { "type": "string" }
      }
    },
    "inputPreconditions": { "type": "string" },
    "expectedDivergence": { "type": "string", "minLength": 1 },
    "grounding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": { "type": "string", "enum": ["authority", "formal-defect-model", "witnessed-failure"] },
        "reference": { "type": "string", "minLength": 1 }
      }
    },
    "negativeControlSignature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedFailureCode", "expectedFirstDivergence", "intendedCheckId"],
      "properties": {
        "expectedFailureCode": { "type": "string" },
        "expectedFirstDivergence": { "type": "string" },
        "intendedCheckId": { "type": "string" }
      }
    }
  }
}
