{
  "$id": "requirement.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requirementId", "scopeItemIds", "statement", "applicability",
    "authorityIds", "requirementClass", "verificationCategories",
    "claimIds", "implementationSurfaces", "requiredProviders"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "requirementId": { "type": "string", "minLength": 1 },
    "scopeItemIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "frameworkOnly": {
      "type": "boolean",
      "description": "true only for framework self-test requirements mandated by the framework spec §24. Framework-only results never satisfy host-product requirements and are excluded from global completion."
    },
    "statement": { "type": "string", "minLength": 1 },
    "applicability": { "type": "string" },
    "authorityIds": { "type": "array", "items": { "type": "string" } },
    "requirementClass": { "type": "string", "minLength": 1 },
    "verificationCategories": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "claimIds": { "type": "array", "items": { "type": "string" } },
    "implementationSurfaces": { "type": "array", "items": { "type": "string" } },
    "requiredProviders": { "type": "array", "items": { "type": "string" } },
    "completionRelevance": { "type": "string" }
  }
}
