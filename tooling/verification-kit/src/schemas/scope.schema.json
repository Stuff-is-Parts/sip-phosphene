{
  "$id": "scope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scopeId", "repositoryIdentity", "userAuthoredText", "governingDocuments",
    "approvedScopeItems", "acceptedVersions", "requiredSubsystems",
    "requiredEnvironments", "requiredCorpora", "exclusions",
    "completionConditions", "authorizationWitnessId"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "scopeId": { "type": "string", "minLength": 1 },
    "repositoryIdentity": { "type": "string", "minLength": 1 },
    "userAuthoredText": {
      "type": "string",
      "minLength": 1,
      "description": "Verbatim user-authored approved-scope text. Upstream authority; never paraphrased."
    },
    "userAuthoredTextSource": { "type": "string" },
    "governingDocuments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["documentId", "path"],
        "properties": {
          "documentId": { "type": "string" },
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        }
      }
    },
    "approvedScopeItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scopeItemId", "title", "source"],
        "properties": {
          "scopeItemId": { "type": "string" },
          "title": { "type": "string" },
          "source": { "type": "string", "description": "Where in userAuthoredText this item is stated." }
        }
      }
    },
    "acceptedVersions": { "type": "object", "additionalProperties": { "type": "string" } },
    "requiredSubsystems": { "type": "array", "items": { "type": "string" } },
    "requiredEnvironments": { "type": "array", "items": { "type": "string" } },
    "requiredCorpora": { "type": "array", "items": { "type": "string" } },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exclusionId", "description", "authorizationWitnessId"],
        "properties": {
          "exclusionId": { "type": "string" },
          "description": { "type": "string" },
          "authorizationWitnessId": { "type": "string" }
        }
      }
    },
    "completionConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "authorizationWitnessId": {
      "type": ["string", "null"],
      "description": "Authenticated authorization witness for scope approval. null means scope approval is pending and every host requirement fails SCOPE_APPROVAL_MISSING."
    }
  }
}
