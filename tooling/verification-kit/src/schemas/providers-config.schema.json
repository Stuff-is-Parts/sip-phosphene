{
  "$id": "providers-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["providers"],
  "properties": {
    "$schema": { "type": "string" },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["providerId", "kind", "command"],
        "properties": {
          "providerId": { "type": "string" },
          "kind": { "type": "string", "enum": ["command", "node-module"] },
          "command": { "type": "string", "description": "Command line (kind=command) or repo-relative module path (kind=node-module)." },
          "export": { "type": "string" },
          "versionCommand": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
