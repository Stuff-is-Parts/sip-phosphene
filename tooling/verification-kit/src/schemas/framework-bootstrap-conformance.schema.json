{
  "$id": "framework-bootstrap-conformance.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bootstrapRecordId", "frameworkSpecificationHash", "frameworkImplementation",
    "canonicalConformanceSuite", "independentBootstrapWitnessId", "decision",
    "reviewedLimitationsOrDeviations", "status"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "bootstrapRecordId": { "type": "string", "minLength": 1 },
    "frameworkSpecificationHash": { "type": "string" },
    "frameworkImplementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositoryIdentity", "reviewedCommit", "reviewedTreeHash", "trustBearingArtifactHashes"],
      "properties": {
        "repositoryIdentity": { "type": "string" },
        "reviewedCommit": { "type": "string" },
        "reviewedTreeHash": { "type": "string" },
        "trustBearingArtifactHashes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string" }
            }
          }
        }
      }
    },
    "canonicalConformanceSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suiteId", "version", "manifestHash"],
      "properties": {
        "suiteId": { "type": "string" },
        "version": { "type": "string" },
        "manifestHash": { "type": "string" }
      }
    },
    "independentBootstrapWitnessId": { "type": ["string", "null"], "description": "Authenticated witness from an authority OUTSIDE the correlated producer (framework spec §7.10A). null while the judgment is pending; pending produces FRAMEWORK_BOOTSTRAP_UNWITNESSED." },
    "decision": { "type": "string" },
    "reviewedLimitationsOrDeviations": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["pending", "established"] }
  }
}
