{
  "$id": "framework-conformance-suite.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suiteId", "version", "manifestHash", "governingSpecificationHash",
    "publicExecutionBoundary", "governance", "semanticContracts",
    "controlScenarios", "sharingRules"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "suiteId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "manifestHash": { "type": "string", "description": "sha256:<hex> over the canonical JSON of this manifest with this field set to 'sha256:SELF'." },
    "governingSpecificationHash": { "type": "string" },
    "publicExecutionBoundary": { "type": "string", "minLength": 1 },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producerMayAddStricterControls", "removalWeakeningReinterpretationOrReplacementRequiresAuthenticatedAuthorization", "adoptionOrChangeWitnessId"],
      "properties": {
        "producerMayAddStricterControls": { "type": "boolean", "const": true },
        "removalWeakeningReinterpretationOrReplacementRequiresAuthenticatedAuthorization": { "type": "boolean", "const": true },
        "adoptionOrChangeWitnessId": { "type": ["string", "null"] }
      }
    },
    "semanticContracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["semanticContractId", "semanticProperty", "requiredControlConditions", "controlScenarioIds", "trustBearingImplementationSurfaces"],
        "properties": {
          "semanticContractId": { "type": "string" },
          "semanticProperty": { "type": "string", "minLength": 1 },
          "requiredControlConditions": {
            "type": "array",
            "items": { "type": "string", "enum": ["positive", "structural-negative", "semantic-negative"] },
            "minItems": 3
          },
          "controlScenarioIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "trustBearingImplementationSurfaces": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "controlScenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenarioId", "condition", "fixtureOrMutationId", "coversSemanticContractIds", "expectedOutcomes"],
        "properties": {
          "scenarioId": { "type": "string" },
          "condition": { "type": "string", "enum": ["positive", "structural-negative", "semantic-negative"] },
          "fixtureOrMutationId": { "type": "string", "description": "The executable control identifier: an audit-control name, negative-control evaluator ID, or fixture-mutation ID run through the public CLI boundary. 'PENDING:<reason>' marks a canonical scenario whose executor is not yet built; pending scenarios keep the suite result FAIL." },
          "coversSemanticContractIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "expectedOutcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["semanticContractId", "expectedResult", "expectedFailureCode", "expectedFirstFailureOrDivergence"],
              "properties": {
                "semanticContractId": { "type": "string" },
                "expectedResult": { "type": "string", "enum": ["PASS", "FAIL"] },
                "expectedFailureCode": { "type": ["string", "null"] },
                "expectedFirstFailureOrDivergence": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "sharingRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sharedScenariosPermitted", "everyCoveredContractMustBeExplicitlyMapped", "expectedOutcomeMustBeIndependentlyAttributablePerContract", "weakeningOneContractMustBreakItsDesignatedControl", "aggregateFixtureCountsMayNotSubstituteForContractCoverage"],
      "properties": {
        "sharedScenariosPermitted": { "type": "boolean", "const": true },
        "everyCoveredContractMustBeExplicitlyMapped": { "type": "boolean", "const": true },
        "expectedOutcomeMustBeIndependentlyAttributablePerContract": { "type": "boolean", "const": true },
        "weakeningOneContractMustBreakItsDesignatedControl": { "type": "boolean", "const": true },
        "aggregateFixtureCountsMayNotSubstituteForContractCoverage": { "type": "boolean", "const": true }
      }
    }
  }
}
