{
  "$id": "fixture.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureId", "requirementIds", "claimIds", "inputArtifact", "expectedArtifact",
    "authorityIds", "evidenceIds", "comparatorId", "fixtureHash", "procedure",
    "discriminates", "discriminationCheckId", "inventoryItemIds"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "fixtureId": { "type": "string", "minLength": 1 },
    "requirementIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "claimIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "inputArtifact": { "type": "string", "minLength": 1 },
    "expectedArtifact": { "type": "string", "minLength": 1 },
    "authorityIds": { "type": "array", "items": { "type": "string" } },
    "evidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "comparatorId": { "type": "string", "minLength": 1 },
    "fixtureHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "sha256 over input artifact bytes + expected artifact bytes."
    },
    "procedure": { "type": "string", "minLength": 1 },
    "discriminates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alternativeId", "evaluatorId", "expectedDivergence"],
        "properties": {
          "alternativeId": { "type": "string" },
          "evaluatorId": { "type": "string" },
          "expectedDivergence": { "type": "string", "description": "JSON path of the first expected divergence when the evaluator runs on this fixture input." }
        }
      }
    },
    "discriminationCheckId": { "type": "string", "minLength": 1 },
    "inventoryItemIds": { "type": "array", "items": { "type": "string" } }
  }
}
