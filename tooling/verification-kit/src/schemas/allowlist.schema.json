{
  "$id": "allowlist.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["identities"],
  "properties": {
    "$schema": { "type": "string" },
    "identities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identityId", "kind", "value"],
        "properties": {
          "identityId": { "type": "string" },
          "kind": { "type": "string", "enum": ["github-account", "signing-key"] },
          "value": { "type": "string", "description": "GitHub login or key fingerprint. Never invented by the producer; supplied by repository administration." },
          "note": { "type": "string" }
        }
      }
    }
  }
}
