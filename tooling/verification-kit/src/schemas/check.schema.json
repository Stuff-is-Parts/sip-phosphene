{
  "$id": "check.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["checkId", "claimIds", "checkType", "adapterId", "capabilityId"],
  "properties": {
    "$schema": { "type": "string" },
    "checkId": { "type": "string", "minLength": 1 },
    "claimIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "checkType": {
      "type": "string",
      "enum": ["subject-execution", "fixture-discrimination", "equivalence-differential", "runtime-effect", "provider"]
    },
    "adapterId": { "type": "string", "minLength": 1 },
    "capabilityId": { "type": "string", "minLength": 1 },
    "providerId": { "type": "string" },
    "operation": { "type": "string" }
  }
}
