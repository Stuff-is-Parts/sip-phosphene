{
  "$id": "witness.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witnessId", "authorizationType", "decision", "affectedIds",
    "authorizingIdentity", "verificationMethod", "timestamp", "reviewedRevision"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "witnessId": { "type": "string", "minLength": 1 },
    "authorizationType": {
      "type": "string",
      "enum": [
        "scope-approval", "scope-change", "scope-exclusion",
        "interpretive-judgment", "regression-authorization",
        "binding-adoption", "binding-adequacy", "allowlist-change",
        "framework-bootstrap-conformance", "framework-change",
        "residual-completeness", "other-reserved-action"
      ]
    },
    "reviewedRevision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "description": "The exact immutable revision the authorization reviews (framework spec §7.10). Mandatory: a witness without it fails AUTHORIZATION_LINEAGE_INVALID."
    },
    "decision": { "type": "string", "minLength": 1 },
    "affectedIds": { "type": "array", "items": { "type": "string" } },
    "authorizingIdentity": { "type": "string", "minLength": 1 },
    "verificationMethod": {
      "type": "string",
      "enum": ["github-approval", "github-repository-administration", "cryptographic-signature", "host-enforced-mechanism"]
    },
    "hostMetadata": { "type": "object", "additionalProperties": true },
    "timestamp": { "type": "string" },
    "retainedVerificationResult": { "type": "string" },
    "adequacyCriteriaExplicitlyJudged": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required for binding-adequacy witnesses: each load-bearing surface the authority explicitly judged."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "authorizationType": { "const": "binding-adequacy" } } },
      "then": { "required": ["adequacyCriteriaExplicitlyJudged"] }
    }
  ]
}
