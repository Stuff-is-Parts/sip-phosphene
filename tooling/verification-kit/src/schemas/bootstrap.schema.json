{
  "$id": "bootstrap.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "repositoryIdentity", "requiredExternalActions"],
  "properties": {
    "$schema": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "established"] },
    "repositoryIdentity": { "type": "string" },
    "initialAllowlistHash": { "type": "string" },
    "establishingMechanism": { "type": "string" },
    "externalActorOrEvent": { "type": "string" },
    "timeEstablished": { "type": "string" },
    "verificationMethod": { "type": "string" },
    "requiredExternalActions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Exact out-of-band actions the user must perform. Present while status is pending; empty once established."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "established" } } },
      "then": { "required": ["initialAllowlistHash", "establishingMechanism", "externalActorOrEvent", "timeEstablished", "verificationMethod"] }
    }
  ]
}
