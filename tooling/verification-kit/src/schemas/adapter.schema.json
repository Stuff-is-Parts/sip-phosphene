{
  "$id": "adapter.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapterId", "role", "description", "capabilities"],
  "properties": {
    "$schema": { "type": "string" },
    "adapterId": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "enum": ["subject", "reference", "product"] },
    "description": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilityId", "module", "export"],
        "properties": {
          "capabilityId": { "type": "string" },
          "module": { "type": "string", "description": "Repo-relative ESM module path." },
          "export": { "type": "string" }
        }
      }
    }
  }
}
