{
  "$id": "authority.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["authorities"],
  "properties": {
    "$schema": { "type": "string" },
    "authorities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityId", "authorityType", "sourceName", "version",
          "locator", "acquisitionMethod", "dateRecorded"
        ],
        "properties": {
          "authorityId": { "type": "string", "minLength": 1 },
          "authorityType": {
            "type": "string",
            "enum": ["specification", "source-code", "binary", "documentation", "dataset", "runtime-observation", "maintained-tool"]
          },
          "sourceName": { "type": "string" },
          "version": { "type": "string", "description": "Exact version, revision, commit, or content hash." },
          "locator": { "type": "string" },
          "sha256": { "type": "string" },
          "retainedPath": { "type": "string" },
          "acquisitionMethod": { "type": "string" },
          "dateRecorded": { "type": "string" },
          "license": { "type": "string" },
          "authorityTier": { "type": "integer", "minimum": 1, "description": "Priority tier per PHOSPHENE-GOAL.md Source Authority ordering; 1 is strongest." },
          "rawArtifact": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "upstreamLocator", "pinnedRevision", "acquisitionCommand",
              "byteLength", "sha256", "retainedPath", "acquisitionDate", "toolVersion"
            ],
            "properties": {
              "upstreamLocator": { "type": "string" },
              "pinnedRevision": { "type": "string" },
              "acquisitionCommand": { "type": "string" },
              "byteLength": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "retainedPath": { "type": "string" },
              "acquisitionDate": { "type": "string" },
              "toolVersion": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
