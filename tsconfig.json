{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["phosphene-engine/src/**/*", "phosphene-engine/check.mjs"],
  // pcm-tap.js runs in AudioWorkletGlobalScope, which the DOM lib does not
  // model (no AudioWorkletProcessor/registerProcessor types); it remains
  // covered by the syntax and lint gate steps.
  "exclude": ["phosphene-engine/src/audio/pcm-tap.js"]
}
